#!/usr/bin/env bash

# Open the target (file, commit, branch, remote, tag) in browser
# Now only support github.com
#
# Usage:
# For file, `open-giturl file <path>` where the path should be based on the git root
#
# Reference: https://github.com/junegunn/fzf-git.sh

if [[ $PWD == $HOME/.config || $PWD == $HOME/.config/* && $PWD != $HOME/.config/nvim/pack* ]]; then
    export GIT_DIR="$HOME/dotfiles"
    export GIT_WORK_TREE="$HOME"
fi

branch=$(git rev-parse --abbrev-ref HEAD 2> /dev/null)

if [[ $branch == HEAD ]]; then
    branch=$(git describe --exact-match --tags 2> /dev/null || git rev-parse --short HEAD)
fi

# $1 is the type of target
case "$1" in
    commit)
        hash=$(grep -o "[a-f0-9]\{7,\}" <<< "$2" | head -n 1)
        path=/commit/$hash
        ;;
    branch|remote-branch)
        branch=$(sed 's/^[* ]*//' <<< "$2" | cut -d' ' -f1)
        remote=$(git config branch."${branch}".remote || echo 'origin')
        branch=${branch#$remote/}
        path=/tree/$branch
        ;;
    remote)
        remote=$2
        path=/tree/$branch
        ;;
    file) path=/blob/$branch/$2 ;; # $2 is the file path that is based on the git root
    tag)  path=/releases/tag/$2 ;;
    *)    exit 1 ;;
esac

remote=${remote:-$(git config branch."${branch}".remote || echo 'origin')}
remote_url=$(git remote get-url "$remote" 2> /dev/null || echo "$remote")

if [[ $remote_url =~ ^git@ ]]; then
    url=${remote_url%.git}
    url=${url#git@}
    url=https://${url/://}
elif [[ $remote_url =~ ^http ]]; then
    url=${remote_url%.git}
fi

open "$url$path"
