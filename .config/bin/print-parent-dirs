#!/usr/bin/env bash

# Print a path's each parent directory, up to /. If the path is a file, start from its containing
# directory.
#
# Usage:
#   print-parent-dir [path]
#   print-parent-dir ./src/main.lua

set -Eeuo pipefail

path="${1:-$PWD}"

if [[ -d "$path" ]]; then
    dir="$(realpath "$path")"
elif [[ -e "$path" ]]; then
    dir="$(dirname "$(realpath "$path")")"
else
    echo "error: path does not exist: $path" >&2
    exit 1
fi

while :; do
    [[ "$dir" == "/" ]] && break
    dir="$(dirname "$dir")"
    printf '%s\n' "$dir"
done
