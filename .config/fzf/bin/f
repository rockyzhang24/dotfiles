#!/usr/bin/env bash

# MNEMONIC: [F]uzzy search
# SYNOPSIS: f [DIR] [FZF ARGS]
# DESCRIPTION: Make FZF support execution under a certain directory

if [[ $# == 0 ]] || [[ $1 =~ ^--\|^- ]]; then
    fzf "$@"
else
    pattern="$1"
    shift
    fd --type f --hidden --follow '.*' "$pattern" 2> /dev/null | fzf "$@"
fi
