#!/usr/bin/env bash

# MNEMONIC: [F]uzzy search [G]it [I]gnore
# SYNOPSIS: fgi [PARAM]
#   [PARAM]: a comma separated (or space separated) list of languages, e.g., fgi c,c++ or fgi c c++
#   If [PARAM] is ommited, choose interactively via fzf.
# DESCRIPTION: Create a gitignore file from gitignore.io

set -euo pipefail

API_BASE="https://www.toptal.com/developers/gitignore/api"

fetch_list() {
    command curl -sL "$API_BASE/list"
}

fetch_gitignore() {
    local langs="$1"
    command curl -sL "$API_BASE/$langs"
}

if  [ "$#" -eq 0 ]; then
    IFS+=","
    for item in $(fetch_list); do
        echo "$item"
    done | fzf --multi --ansi --prompt="GitIgnore> " --preview "command curl -sL $API_BASE/{} | bat -p -l gitignore --color=always" | paste -s -d "," - |
    { read -r result && fetch_gitignore "$result"; }
else
    IFS=","
    fetch_gitignore "$*"
fi
