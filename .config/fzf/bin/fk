#!/usr/bin/env bash

# MNEMONIC: [F]uzzy search [K]ill
# SYNOPSIS: fk
# DESCRIPTION: Fuzzy finder for a process of $UID to kill.

set -euo pipefail

signal="${1:-9}"

if [[ "${UID:-$(id -u)}" -eq 0 ]]; then
    ps_cmd='ps -ef'
else
    ps_cmd="ps -f -u $UID"
fi

opts=(
    --multi
    --header=$':: ENTER (kill), CTRL-R (reload)\n\n'
    --header-lines=2
    --preview='echo {}'
    --preview-window='down,30%,wrap'
    --preview-label '[ Process Information ]'
    --bind 'start:unbind(focus)'
    --bind "ctrl-r:reload($ps_cmd)"
)

selection="$($ps_cmd | fzf "${opts[@]}")" || exit 0

awk '{print $2}' <<< "$selection" | xargs kill "-$signal"
